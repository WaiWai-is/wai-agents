# ===========================================
# WaiAgents Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# ----- Database -----
DATABASE_URL=postgres://user:password@localhost:5432/wai_agents_dev

# ----- Auth -----
JWT_SECRET=change-me-in-production

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- Internal API -----
INTERNAL_API_KEY=change-me-in-production

# ----- S3 / Object Storage -----
S3_ENDPOINT=https://your-endpoint.com
S3_REGION=eu-central-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=open-raccoon
MCP_API_KEY=change-me-in-production

# ----- LLM API Keys -----
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# ----- MCP Server Ports -----
MCP_MEMORY_PORT=3100
MCP_WEB_SEARCH_PORT=3101
MCP_PR_TOOLS_PORT=3102
MCP_AGENT_COMM_PORT=3103

# ----- API Server -----
PORT=4000
API_PORT=4000
NODE_ENV=development

# ----- Web (Next.js) -----
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=
API_PROXY_TARGET=http://127.0.0.1:4000
